# =============================================================================
# MedScribe AI — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# --- Supabase ---
# Get these from: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Deepgram ---
# Get from: https://console.deepgram.com → API Keys
DEEPGRAM_API_KEY=your-deepgram-key-here

# --- Anthropic (Claude) ---
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your-anthropic-key-here

# --- OpenAI (fallback AI + STT fallback) ---
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key-here

# --- Google Gemini (AI fallback) ---
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=your-gemini-key-here

# --- Google Cloud Speech-to-Text (STT 3rd fallback) ---
# Same GCP project key works if the Speech-to-Text API is enabled on it.
# Enable at: https://console.cloud.google.com/apis/library/speech.googleapis.com
# Get API key: https://console.cloud.google.com/apis/credentials
# Note: sync endpoint supports max ~60s audio; longer recordings are skipped.
GOOGLE_CLOUD_STT_API_KEY=your-google-cloud-api-key-here

# --- AI Pipeline Service ---
# URL where the Python FastAPI service is running
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# --- JWT (Supabase JWT secret) ---
# Get from: Supabase Dashboard → Settings → API → JWT Secret
JWT_SECRET=your-supabase-jwt-secret

# --- Optional: EHR Integration ---
# FHIR_SERVER_URL=https://your-ehr-fhir-endpoint
# FHIR_CLIENT_ID=your-fhir-client-id
# FHIR_CLIENT_SECRET=your-fhir-client-secret
